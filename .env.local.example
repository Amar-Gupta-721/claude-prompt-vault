# MongoDB Connection String
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/claude-prompt-vault?retryWrites=true&w=majority

# JWT Secret (generate a long random string)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Admin credentials (used for first-time setup)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your-admin-password

# Next.js
NEXTAUTH_URL=http://localhost:3000

# ── HOW TO SEED ──────────────────────────────────────────────────────────────
# After starting the dev server, just open this URL in your browser once:
#   http://localhost:3000/api/admin/seed
# It will create the admin account using ADMIN_USERNAME + ADMIN_PASSWORD above,
# and seed all prompts & skills. Safe to call again — it won't duplicate data.
